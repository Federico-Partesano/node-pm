{
  "name": "node-pm",
  "version": "0.0.0",
  "description": "TUI-first manager for local Node project repositories",
  "type": "module",
  "bin": {
    "pm": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src test",
    "release": "changeset publish"
  },
  "dependencies": {
    "@napi-rs/keyring": "^1.1.0",
    "commander": "^12.0.0",
    "env-paths": "^3.0.0",
    "execa": "^9.0.0",
    "ink": "^5.0.0",
    "ink-progress-bar": "^3.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "octokit": "^4.0.0",
    "p-queue": "^8.0.0",
    "platform-folders": "^0.6.0",
    "react": "^18.3.0",
    "simple-git": "^3.25.0",
    "write-file-atomic": "^6.0.0",
    "yauzl": "^3.3.0",
    "yazl": "^2.5.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/write-file-atomic": "^4.0.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^2.4.6",
    "@vitest/coverage-v8": "^2.0.0",
    "eslint": "^9.0.0",
    "ink-testing-library": "^4.0.0",
    "memfs": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
